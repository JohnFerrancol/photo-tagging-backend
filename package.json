{
  "name": "express-template",
  "version": "1.0.0",
  "description": "",
  "scripts": {
    "lint": "eslint .",
    "format:js": "prettier --write 'routes/**/*.js' 'controllers/**/*.js' 'middleware/**/*.js'",
    "format:ejs": "prettier --plugin=prettier-plugin-ejs --write 'views/**/*.ejs'",
    "format": "npm run format:js && npm run format:ejs",
    "start": "node --watch src/server.js",
    "explore": "prisma studio --config ./prisma.config.js",
    "prisma:gen": "npx prisma generate",
    "prisma:migrate": "npx prisma migrate deploy",
    "seed": "node prisma/seed/seed.js",
    "upload": "node prisma/seed/uploadAssets.js",
    "build": "npm install && npm run prisma:gen && npm run prisma:migrate && npm run upload && npm run seed"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "@supabase/supabase-js": "^2.103.3",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-validator": "^7.3.2",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.4.0",
    "prettier": "^3.8.1",
    "prettier-plugin-ejs": "^1.0.3",
    "prisma": "^7.7.0"
  }
}
